{
  "name": "@keepdevops/cofiswarm-ui",
  "version": "2.1.4",
  "description": "Cofiswarm Brew UI (React)",
  "license": "LicenseRef-Coficube-Proprietary",
  "author": "Bret Kuhne <keepdevops@gmail.com> (Coficube)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keepdevops/cofiswarm-ui.git"
  },
  "homepage": ".",
  "bugs": {
    "url": "https://github.com/keepdevops/cofiswarmdev/issues"
  },
  "keywords": [
    "matrix",
    "llm",
    "proxy",
    "coordinator",
    "swarm",
    "agents"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "prestart": "node scripts/ensure-react-scripts-patch.mjs",
    "start": "NODE_NO_WARNINGS=1 REACT_APP_VERSION=$npm_package_version react-scripts start",
    "build": "REACT_APP_VERSION=$npm_package_version react-scripts build",
    "test": "react-scripts test --watchAll=false",
    "prepack": "npm run build && npm run stage:dist",
    "prepublishOnly": "echo 'Publishing to npm is disabled for this project.' && exit 1",
    "postinstall": "(patch-package || true) && node scripts/postinstall.mjs"
  },
  "devDependencies": {
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/view": "^6.35.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@uiw/codemirror-theme-vscode": "^4.25.4",
    "@uiw/react-codemirror": "^4.25.4",
    "patch-package": "^8.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "overrides": {
    "nth-check": ">=2.0.1",
    "postcss": ">=8.5.10",
    "serialize-javascript": ">=7.0.5",
    "underscore": ">=1.13.8",
    "@tootallnate/once": ">=3.0.1",
    "yaml": "^1.10.3",
    "webpack-dev-server": {
      ".": "^5.2.4",
      "ws": ">=8.20.1"
    },
    "lodash": ">=4.18.1",
    "follow-redirects": ">=1.16.0",
    "uuid": ">=14.0.0",
    "shell-quote": ">=1.8.4",
    "tmp": ">=0.2.6",
    "@babel/plugin-transform-modules-systemjs": ">=7.29.4",
    "fast-uri": ">=3.1.2",
    "qs": ">=6.15.2"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  }
}